bouldering_wall "Wall5" {
  routes [
    bouldering_route "InvalidRoute" {
      grade: "5A",
      grid_base_point { x: 0, y: 0 },
      holds ["0001", "0002", {"0003", "0004"}, "0007", {"0005", "0006"}]
    }
